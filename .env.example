# VoiceBot Environment Configuration
ENVIRONMENT=development
LOG_LEVEL=INFO

# ASR Configuration
ASR_MODEL=base          # tiny | base | small | medium | large
ASR_LANGUAGE=en
ASR_DEVICE=cpu          # cpu | cuda

# Intent Classification
INTENT_CONFIDENCE_THRESHOLD=0.5
MAX_SEQ_LENGTH=128

# TTS Configuration
TTS_ENGINE=gtts         # gtts | pyttsx3
TTS_SPEAKING_RATE=1.0   # 0.5 - 2.0

# API Settings
API_PORT=8000
MAX_UPLOAD_SIZE_MB=25
